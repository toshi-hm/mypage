{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "tests/**/*",
    "scripts/**/*",
    ".storybook/**/*",
    "*.ts"
  ],
  "exclude": ["dist", "node_modules", "storybook-static"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["bun"],
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
