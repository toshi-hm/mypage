{
  "name": "mypage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "preview:cf": "wrangler dev",
    "lint": "oxlint",
    "lint:md": "markdownlint-cli2",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "astro check && tsc --noEmit",
