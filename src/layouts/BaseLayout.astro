---
import SiteFooter from "../components/organisms/SiteFooter.astro";
import SiteHeader from "../components/organisms/SiteHeader.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	/** ページに埋め込む JSON-LD(構造化データ)。src/utils/structured-data.ts で組み立てる */
	jsonLd?: Record<string, unknown>;
}

const { title, description = SITE_DESCRIPTION, jsonLd } = Astro.props;
const pageTitle = title === "Home" ? SITE_TITLE : `${title} | Hama Toshiya`;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={SITE_TITLE} />
		{canonicalURL && <link rel="canonical" href={canonicalURL} />}
		{canonicalURL && <meta property="og:url" content={canonicalURL} />}
		<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<title>{pageTitle}</title>
		{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, "\\u003c")} />}
		<script is:inline>
			// FOUC 防止のため、テーマを描画前に適用する
			const stored = localStorage.getItem("theme");
			const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
			const theme = stored === "light" || stored === "dark" ? stored : prefersDark ? "dark" : "light";
			document.documentElement.dataset.theme = theme;
		</script>
	</head>
	<body>
		<a class="skip-link" href="#main">本文へスキップ</a>
		<SiteHeader />
		<main id="main">
			<slot />
		</main>
		<SiteFooter />
	</body>
</html>

<style>
	/* キーボードフォーカス時のみ現れるスキップリンク(WCAG 2.4.1) */
	.skip-link {
		position: fixed;
		left: 0.5rem;
		top: 0.5rem;
		z-index: 100;
		padding: 0.5rem 1rem;
		background: var(--color-text);
		color: var(--color-surface);
		border-radius: var(--radius);
		transform: translateY(-300%);
	}

	.skip-link:focus {
		transform: none;
	}
</style>
