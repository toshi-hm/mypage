---
import { formatDate } from "../utils/articles";

interface Props {
	slug: string;
	title: string;
	summary: string;
	pubDate: Date;
	tags?: string[];
}

const { slug, title, summary, pubDate, tags = [] } = Astro.props;
---

<article class="card">
	<a href={`/articles/${slug}/`}>
		<h3>{title}</h3>
		{summary && <p class="summary">{summary}</p>}
		<footer>
			<time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
			{
				tags.length > 0 && (
					<ul class="tags">
						{tags.map((tag) => (
							<li>{tag}</li>
						))}
					</ul>
				)
			}
		</footer>
	</a>
</article>

<style>
	.card a {
		display: block;
		padding: 1rem 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		text-decoration: none;
		color: var(--color-text);
		transition: border-color 0.15s ease;
	}

	.card a:hover {
		border-color: var(--color-accent);
	}

	h3 {
		margin: 0 0 0.25rem;
		font-size: 1.1rem;
	}

	.summary {
		margin: 0 0 0.5rem;
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

	footer {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}

	.tags {
		display: flex;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.tags li {
		padding: 0.05rem 0.5rem;
		border-radius: 999px;
		background: var(--color-accent-soft);
		color: var(--color-accent);
		font-weight: 600;
	}
</style>
