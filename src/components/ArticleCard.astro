---
import { formatDate } from "../utils/articles";
import TagList from "./TagList.astro";

interface Props {
	slug: string;
	title: string;
	summary: string;
	pubDate: Date;
	tags?: string[];
}

const { slug, title, summary, pubDate, tags = [] } = Astro.props;
---

<article class="row">
	<div class="head">
		<h2><a href={`/articles/${slug}/`}>{title}</a></h2>
		<time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
	</div>
	{summary && <p class="summary">{summary}</p>}
	<TagList tags={tags} />
</article>

<style>
	/* 索引行スタイル: 箱ではなく罫線で区切る */
	.row {
		position: relative;
		border-top: 1px solid var(--color-border);
		padding: 0.9rem 0.25rem 1rem;
	}

	.row:hover {
		border-top-color: var(--color-accent);
		background: linear-gradient(to right, var(--color-accent-soft), transparent 65%);
	}

	.head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
	}

	h2 {
		margin: 0;
		font-size: 1.05rem;
	}

	h2 a {
		color: var(--color-text);
		text-decoration: none;
	}

	/* カード全体をタイトルリンクのクリック領域にする(タグリンクは上に重なる) */
	h2 a::after {
		content: "";
		position: absolute;
		inset: 0;
	}

	.row :global(.tags) {
		position: relative;
		z-index: 1;
	}

	time {
		flex-shrink: 0;
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}

	.summary {
		margin: 0.25rem 0 0.5rem;
		font-size: 0.88rem;
		color: var(--color-text-muted);
	}
</style>
