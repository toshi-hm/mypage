---
import { formatDate } from "../utils/articles";
import TagList from "./TagList.astro";

interface Props {
	slug: string;
	title: string;
	summary: string;
	pubDate: Date;
	tags?: string[];
}

const { slug, title, summary, pubDate, tags = [] } = Astro.props;
---

<article class="card">
	<h3><a href={`/articles/${slug}/`}>{title}</a></h3>
	{summary && <p class="summary">{summary}</p>}
	<footer>
		<time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
		<TagList tags={tags} />
	</footer>
</article>

<style>
	.card {
		padding: 1rem 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		transition: border-color 0.15s ease;
	}

	.card:hover {
		border-color: var(--color-accent);
	}

	h3 {
		margin: 0 0 0.25rem;
		font-size: 1.1rem;
	}

	h3 a {
		color: var(--color-text);
		text-decoration: none;
	}

	h3 a::after {
		/* カード全体をタイトルリンクのクリック領域にする(タグリンクは上に重なる) */
		content: "";
		position: absolute;
		inset: 0;
	}

	.card {
		position: relative;
	}

	.card footer :global(.tags) {
		position: relative;
		z-index: 1;
	}

	.summary {
		margin: 0 0 0.5rem;
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

	footer {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}
</style>
