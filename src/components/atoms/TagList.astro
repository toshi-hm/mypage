---
interface Props { tags: string[]; }
const { tags } = Astro.props;
---

{tags.length > 0 && (
  <ul class="tags">
    {tags.map((tag) => <li><a href={`/tags/${tag}/`}>#{tag}</a></li>)}
  </ul>
)}

<style>
  .tags { display: flex; flex-wrap: wrap; gap: .4rem; list-style: none; margin: 0; padding: 0; }
  .tags a { display: inline-flex; align-items: center; min-height: 1.8rem; padding: .15rem .6rem; border: 1px solid var(--color-border); border-radius: 999px; background: var(--color-surface); color: var(--color-text-muted); font: 700 .7rem/1 var(--font-mono); text-decoration: none; }
  .tags a:hover { border-color: var(--color-accent); color: var(--color-accent); transform: translateY(-1px); }
</style>
