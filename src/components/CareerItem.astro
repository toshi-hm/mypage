---
import { formatPeriod } from "../utils/career";

interface Props {
	role: string;
	organization: string;
	startDate: string;
	endDate?: string | undefined;
	description: string;
}

const { role, organization, startDate, endDate, description } = Astro.props;
---

<li class="item">
	<p class="period mono">{formatPeriod(startDate, endDate)}</p>
	<div class="body">
		<h3>{role}</h3>
		<p class="organization">{organization}</p>
		<p class="description">{description}</p>
	</div>
</li>

<style>
	.item {
		display: grid;
		grid-template-columns: 9rem 1fr;
		gap: 0.5rem 1.25rem;
		border-top: 1px solid var(--color-border);
		padding: 0.9rem 0.25rem 1rem;
	}

	.item:hover {
		border-top-color: var(--color-accent);
	}

	.period {
		margin: 0;
		font-size: 0.8rem;
		color: var(--color-text-muted);
		white-space: nowrap;
	}

	.body {
		min-width: 0;
	}

	h3 {
		margin: 0;
		font-size: 1.05rem;
	}

	.organization {
		margin: 0.15rem 0 0;
		font-size: 0.88rem;
		color: var(--color-accent);
	}

	.description {
		margin: 0.35rem 0 0;
		font-size: 0.88rem;
		color: var(--color-text-muted);
	}

	@media (max-width: 480px) {
		.item {
			grid-template-columns: 1fr;
		}
	}
</style>
