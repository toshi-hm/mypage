---
import HeroVisual from "../islands/HeroVisual";
---

<section class="hero">
  <HeroVisual client:media="(min-width: 821px)" />
  <div class="intro">
    <p class="eyebrow">Software Engineer · Tokyo</p>
    <h1>Building<span class="mobile-break"><br /></span> digital<br />experiences with<br /><span>clarity &amp; character.</span></h1>
    <p class="lead">使いやすさの中に、少しの驚きを。設計から実装まで、長く愛されるプロダクト体験をつくります。</p>
    <div class="actions"><a class="primary" href="/works/">View my work <span aria-hidden="true">↗</span></a><a class="secondary" href="/about/">About me</a></div>
  </div>
  <aside aria-label="プロフィール概要">
    <p class="availability"><span aria-hidden="true"></span>Open to new ideas</p>
    <dl><div><dt>Focus</dt><dd>Web / Product<br />Engineering</dd></div><div><dt>Stack</dt><dd>TypeScript<br />Astro · React</dd></div></dl>
  </aside>
</section>

<style>
  .hero { position: relative; display: grid; grid-template-columns: minmax(0, 1fr) 14rem; gap: 3rem; min-height: min(46rem, calc(100dvh - 6rem)); padding: clamp(3.5rem, 8vw, 7rem) 0 4rem; align-items: end; isolation: isolate; }
  .hero :global(.hero-visual) { position: absolute; inset: 0; z-index: -1; pointer-events: none; opacity: .55; }
  .intro { max-width: 58rem; }
  h1 { font-size: clamp(3.3rem, 8vw, 7.6rem); line-height: .94; }
  h1 > span:not(.mobile-break) { position: relative; color: var(--color-accent); white-space: nowrap; }
  h1 .mobile-break { display: none; }
  h1 > span:not(.mobile-break)::after { content: ""; position: absolute; left: -.03em; right: -.03em; bottom: -.06em; height: .09em; border-radius: 999px; background: var(--color-highlight); z-index: -1; transform: rotate(-1deg); }
  .lead { max-width: 39rem; margin: 2rem 0; color: var(--color-text-muted); font-size: clamp(1rem, 2vw, 1.2rem); }
  .actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .actions a { display: inline-flex; align-items: center; justify-content: center; min-height: 3.25rem; padding: .7rem 1.25rem; border-radius: 999px; font-weight: 750; text-decoration: none; }
  .primary { gap: .8rem; background: var(--color-text); color: var(--color-bg); }
  .primary span { display: grid; place-items: center; width: 1.7rem; aspect-ratio: 1; border-radius: 50%; background: var(--color-highlight); color: var(--color-on-highlight); }
  .secondary { color: var(--color-text); border: 1px solid var(--color-border); background: var(--color-surface); }
  aside { align-self: center; padding: 1.2rem; border: 1px solid var(--color-border); border-radius: var(--radius) var(--radius-sm) var(--radius) var(--radius); background: color-mix(in srgb, var(--color-surface) 84%, transparent); box-shadow: var(--shadow-sm); backdrop-filter: blur(10px); transform: rotate(1.5deg); }
  .availability { margin: 0 0 1.5rem; color: var(--color-text-muted); font: 700 .7rem/1.4 var(--font-mono); }
  .availability span { display: inline-block; width: .55rem; aspect-ratio: 1; margin-right: .4rem; border-radius: 50%; background: var(--color-success); box-shadow: 0 0 0 .25rem color-mix(in srgb, var(--color-success) 18%, transparent); }
  dl, dl div { display: grid; gap: .25rem; }
  dl { margin: 0; gap: 1rem; }
  dt { color: var(--color-text-muted); font: 700 .65rem/1 var(--font-mono); text-transform: uppercase; }
  dd { margin: 0; font-size: .85rem; font-weight: 700; line-height: 1.45; }
  @media (max-width: 820px) { .hero { grid-template-columns: 1fr; min-height: auto; } .hero :global(.hero-visual), aside { display: none; } }
  @media (max-width: 540px) { .hero { padding-top: 3rem; } h1 { font-size: clamp(2.65rem, 12vw, 3.25rem); } h1 > span:not(.mobile-break) { white-space: normal; } h1 .mobile-break { display: inline; } .lead { font-size: .95rem; } }
</style>
