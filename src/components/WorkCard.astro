---
interface Props {
	name: string;
	description: string;
	url?: string | undefined;
	repo?: string | undefined;
	tech?: string[];
}

const { name, description, url, repo, tech = [] } = Astro.props;
---

<article class="card">
	<h3>{name}</h3>
	<p class="description">{description}</p>
	{
		tech.length > 0 && (
			<ul class="tech">
				{tech.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		)
	}
	<footer>
		{
			url && (
				<a href={url} target="_blank" rel="noopener noreferrer">
					Site ↗
				</a>
			)
		}
		{
			repo && (
				<a href={repo} target="_blank" rel="noopener noreferrer">
					Repository ↗
				</a>
			)
		}
	</footer>
</article>

<style>
	.card {
		padding: 1rem 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
	}

	h3 {
		margin: 0 0 0.25rem;
		font-size: 1.1rem;
	}

	.description {
		margin: 0 0 0.5rem;
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

	.tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0 0 0.5rem;
		padding: 0;
		font-size: 0.8rem;
	}

	.tech li {
		padding: 0.05rem 0.5rem;
		border-radius: 999px;
		background: var(--color-accent-soft);
		color: var(--color-accent);
		font-weight: 600;
	}

	footer {
		display: flex;
		gap: 1rem;
		font-size: 0.85rem;
	}
</style>
