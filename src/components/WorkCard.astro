---
interface Props {
	name: string;
	description: string;
	url?: string | undefined;
	repo?: string | undefined;
	tech?: string[];
}

const { name, description, url, repo, tech = [] } = Astro.props;
---

<article class="row">
	<div class="head">
		<h2>{name}</h2>
		<span class="links">
			{
				url && (
					<a href={url} target="_blank" rel="noopener noreferrer">
						Site<span aria-hidden="true">&nbsp;↗</span>
					</a>
				)
			}
			{
				repo && (
					<a href={repo} target="_blank" rel="noopener noreferrer">
						Repository<span aria-hidden="true">&nbsp;↗</span>
					</a>
				)
			}
		</span>
	</div>
	<p class="description">{description}</p>
	{
		tech.length > 0 && (
			<ul class="tech">
				{tech.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		)
	}
</article>

<style>
	.row {
		border-top: 1px solid var(--color-border);
		padding: 0.9rem 0.25rem 1rem;
	}

	.row:hover {
		border-top-color: var(--color-accent);
	}

	.head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	h2 {
		margin: 0;
		font-size: 1.05rem;
	}

	.links {
		display: flex;
		gap: 1rem;
		font-size: 0.85rem;
		font-family: var(--font-mono);
	}

	.description {
		margin: 0.25rem 0 0.5rem;
		font-size: 0.88rem;
		color: var(--color-text-muted);
	}

	.tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 0.75rem;
		list-style: none;
		margin: 0;
		padding: 0;
		font-size: 0.78rem;
		font-family: var(--font-mono);
		color: var(--color-text-muted);
	}

	.tech li::before {
		content: "#";
		color: var(--color-accent);
	}
</style>
