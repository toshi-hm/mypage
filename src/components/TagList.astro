---
interface Props {
	tags: string[];
}

const { tags } = Astro.props;
---

{
	tags.length > 0 && (
		<ul class="tags">
			{tags.map((tag) => (
				<li>
					<a href={`/tags/${tag}/`}>#{tag}</a>
				</li>
			))}
		</ul>
	)
}

<style>
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 0.75rem;
		list-style: none;
		margin: 0;
		padding: 0;
		font-size: 0.78rem;
		font-family: var(--font-mono);
	}

	.tags a {
		display: inline-block;
		padding: 0.25rem 0;
		color: var(--color-accent);
		text-decoration: none;
	}

	.tags a:hover {
		text-decoration: underline;
		text-decoration-thickness: 2px;
	}
</style>
