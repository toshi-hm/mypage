---
interface Props { index: string; title: string; id?: string; href?: string; linkLabel?: string; }
const { index, title, id, href, linkLabel = "View all" } = Astro.props;
---

<div class="heading">
  <h2 id={id}><span>{index}</span>{title}</h2>
  {href && <a href={href}>{linkLabel}<span aria-hidden="true"> ↗</span></a>}
</div>

<style>
  .heading { display: flex; align-items: end; justify-content: space-between; gap: 1rem; margin: clamp(4rem, 9vw, 7rem) 0 1.25rem; padding-bottom: .8rem; border-bottom: 1px solid var(--color-rule); }
  h2 { display: flex; align-items: baseline; gap: .75rem; margin: 0; font-size: clamp(1.3rem, 3vw, 2.2rem); font-weight: 750; letter-spacing: -.03em; }
  h2 span { color: var(--color-accent); font: 700 .72rem/1 var(--font-mono); letter-spacing: .08em; }
  a { flex: none; color: var(--color-text); font: 700 .78rem/1 var(--font-mono); text-decoration: none; }
  a:hover { color: var(--color-accent); }
</style>
