---
import { formatPeriod } from "../../utils/career";
interface Props { role: string; organization: string; track?: "education" | "work"; startDate: string; endDate?: string; description: string; highlights?: string[]; }
const { role, organization, track = "education", startDate, endDate, description, highlights = [] } = Astro.props;
---

<article class:list={["career-item", track]}>
  <p class="period mono">{formatPeriod(startDate, endDate)}</p>
  <div class="content">
    <p class="organization">{organization}</p>
    <h3>{role}</h3>
    <p class="description">{description}</p>
    {highlights.length > 0 && <ul class="highlights" aria-label="関連キーワード">{highlights.map((highlight) => <li>{highlight}</li>)}</ul>}
  </div>
</article>

<style>
  .career-item { position: relative; display: grid; gap: .9rem; padding: clamp(1.25rem, 3vw, 1.7rem); border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface); box-shadow: var(--shadow-sm); overflow: hidden; transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease; }
  .career-item:hover { border-color: color-mix(in srgb, var(--color-accent) 50%, var(--color-border)); box-shadow: var(--shadow-lg); transform: translateY(-5px); }
  .career-item.work:hover { border-color: color-mix(in srgb, var(--color-coral) 60%, var(--color-border)); }
  .career-item::before { content: ""; position: absolute; inset: 0 auto 0 0; width: .32rem; background: var(--color-accent); }
  .career-item.work::before { background: var(--color-coral); }
  p { margin: 0; }
  .period { width: fit-content; padding: .25rem .55rem; border-radius: 999px; background: var(--color-accent-soft); color: var(--color-accent); font-size: .7rem; font-weight: 750; }
  .work .period { background: color-mix(in srgb, var(--color-coral) 14%, var(--color-surface)); color: var(--color-text); }
  .organization { color: var(--color-accent); font: 700 .74rem/1.4 var(--font-mono); text-transform: uppercase; }
  .work .organization { color: color-mix(in srgb, var(--color-coral) 64%, var(--color-text)); }
  h3 { margin: .35rem 0 .5rem; font-size: 1.2rem; }
  .description { color: var(--color-text-muted); font-size: .9rem; }
  .highlights { display: flex; flex-wrap: wrap; gap: .4rem; list-style: none; margin: 1rem 0 0; padding: 0; }
  .highlights li { padding: .25rem .55rem; border: 1px solid var(--color-border); border-radius: 999px; color: var(--color-text-muted); font: 700 .68rem/1.4 var(--font-mono); }
</style>
