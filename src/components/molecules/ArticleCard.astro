---
import { formatDate } from "../../utils/articles";
import TagList from "../atoms/TagList.astro";
interface Props { slug: string; title: string; summary: string; pubDate: Date; tags?: string[]; }
const { slug, title, summary, pubDate, tags = [] } = Astro.props;
---

<article class="article-card">
  <div class="meta"><time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time><span aria-hidden="true">Read</span></div>
  <h2><a href={`/articles/${slug}/`}>{title}</a></h2>
  {summary && <p>{summary}</p>}
  <TagList tags={tags} />
</article>

<style>
  .article-card { position: relative; display: grid; align-content: start; min-height: 15rem; padding: 1.4rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface); box-shadow: var(--shadow-sm); transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease; overflow: hidden; }
  .article-card::before { content: ""; position: absolute; width: 5rem; height: 5rem; right: -2.5rem; top: -2.5rem; border-radius: 50%; background: var(--color-highlight); opacity: .8; }
  .article-card:hover { border-color: var(--color-accent); transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .meta { display: flex; justify-content: space-between; gap: 1rem; color: var(--color-text-muted); font: 600 .7rem/1.3 var(--font-mono); text-transform: uppercase; }
  h2 { margin: 2rem 0 .65rem; font-size: clamp(1.2rem, 2.2vw, 1.65rem); }
  h2 a { color: var(--color-text); text-decoration: none; }
  h2 a::after { content: ""; position: absolute; inset: 0; }
  p { margin: 0 0 1.25rem; color: var(--color-text-muted); font-size: .9rem; }
  .article-card :global(.tags) { position: relative; z-index: 1; margin-top: auto; }
</style>
