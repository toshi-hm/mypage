---
import { getCollection } from "astro:content";
import CareerItem from "../components/CareerItem.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortCareer } from "../utils/career";

const skills = ["TypeScript", "Astro", "React", "Bun", "Cloudflare"];
const career = sortCareer(await getCollection("career"));
---

<BaseLayout title="About" description="Hama Toshiya のプロフィール">
	<h1>About</h1>
	<p>Hama Toshiya のプロフィールページです。</p>

	<h2>Skills</h2>
	<ul class="skills">
		{skills.map((skill) => <li>{skill}</li>)}
	</ul>

	{
		career.length > 0 && (
			<>
				<h2>Career</h2>
				<ul class="career">
					{career.map((item) => (
						<CareerItem
							role={item.data.role}
							organization={item.data.organization}
							startDate={item.data.startDate}
							endDate={item.data.endDate}
							description={item.data.description}
						/>
					))}
				</ul>
			</>
		)
	}

	<h2>このサイトについて</h2>
	<p>
		Astro 7(静的出力)+ React islands 構成。詳細は
		<a href="https://github.com/toshi-hm/mypage">リポジトリ</a>
		の <code>docs/design.md</code> を参照してください。
	</p>
</BaseLayout>

<style>
	.career {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.skills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		padding: 0;
	}

	.skills li {
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
		background: var(--color-accent-soft);
		color: var(--color-accent);
		font-size: 0.85rem;
		font-weight: 600;
	}
</style>
