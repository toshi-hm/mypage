---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="ページが見つかりません">
	<section class="not-found">
		<h1>404</h1>
		<p>お探しのページは見つかりませんでした。</p>
		<a href="/">トップへ戻る</a>
	</section>
</BaseLayout>

<style>
	.not-found {
		text-align: center;
		padding: 4rem 0;
	}

	.not-found h1 {
		font-size: 4rem;
		margin: 0;
		color: var(--color-accent);
	}
</style>
