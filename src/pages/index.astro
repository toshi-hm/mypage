---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import LinkCard from "../components/LinkCard.astro";
import WorkCard from "../components/WorkCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { excerpt, isPublishable, sortByPubDateDesc } from "../utils/articles";
import { sortWorks } from "../utils/works";

const latestArticles = sortByPubDateDesc(
	await getCollection("articles", ({ data }) => isPublishable(data, import.meta.env.PROD)),
).slice(0, 3);
const featuredWorks = sortWorks(await getCollection("works", ({ data }) => data.featured));
---

<BaseLayout title="Home">
	<section class="hero">
		<h1>こんにちは、toshi-hm です</h1>
		<p>
			ソフトウェアエンジニアです。このサイトは Astro + TypeScript で作られ、Cloudflare
			で配信される予定の個人ホームページです。
		</p>
	</section>

	{
		latestArticles.length > 0 && (
			<section>
				<h2>Latest Articles</h2>
				<div class="cards">
					{latestArticles.map((article) => (
						<ArticleCard
							slug={article.id}
							title={article.data.title}
							summary={excerpt(article.data, article.body)}
							pubDate={article.data.pubDate}
							tags={article.data.tags}
						/>
					))}
				</div>
				<p class="more">
					<a href="/articles/">すべての記事を見る →</a>
				</p>
			</section>
		)
	}

	{
		featuredWorks.length > 0 && (
			<section>
				<h2>Featured Works</h2>
				<div class="cards">
					{featuredWorks.map((work) => (
						<WorkCard
							name={work.data.name}
							description={work.data.description}
							url={work.data.url}
							repo={work.data.repo}
							tech={work.data.tech}
						/>
					))}
				</div>
				<p class="more">
					<a href="/works/">すべての制作物を見る →</a>
				</p>
			</section>
		)
	}

	<section>
		<h2>Links</h2>
		<div class="cards">
			<LinkCard title="About" href="/about/" description="プロフィール・スキル・経歴" />
			<LinkCard
				title="GitHub"
				href="https://github.com/toshi-hm"
				description="公開リポジトリはこちら"
			/>
		</div>
	</section>
</BaseLayout>

<style>
	.hero {
		padding: 2rem 0;
	}

	.hero h1 {
		font-size: 2rem;
		margin: 0 0 0.75rem;
	}

	.hero p {
		color: var(--color-text-muted);
		margin: 0;
	}

	.cards {
		display: grid;
		gap: 0.75rem;
	}
</style>
