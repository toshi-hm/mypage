---
import LinkCard from "../components/LinkCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
	<section class="hero">
		<h1>こんにちは、toshi-hm です</h1>
		<p>
			ソフトウェアエンジニアです。このサイトは Astro + TypeScript で作られ、Cloudflare
			で配信される予定の個人ホームページです。
		</p>
	</section>

	<section>
		<h2>Links</h2>
		<div class="cards">
			<LinkCard title="About" href="/about/" description="プロフィール・スキル・経歴" />
			<LinkCard
				title="GitHub"
				href="https://github.com/toshi-hm"
				description="公開リポジトリはこちら"
			/>
		</div>
	</section>
</BaseLayout>

<style>
	.hero {
		padding: 2rem 0;
	}

	.hero h1 {
		font-size: 2rem;
		margin: 0 0 0.75rem;
	}

	.hero p {
		color: var(--color-text-muted);
		margin: 0;
	}

	.cards {
		display: grid;
		gap: 0.75rem;
	}
</style>
