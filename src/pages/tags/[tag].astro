---
import { getCollection } from "astro:content";
import ArticleCard from "../../components/molecules/ArticleCard.astro";
import PageHeader from "../../components/molecules/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectTags, excerpt, isPublishable, sortByPubDateDesc } from "../../utils/articles";

export async function getStaticPaths() {
	const articles = await getCollection("articles", ({ data }) =>
		isPublishable(data, import.meta.env.PROD),
	);
	return collectTags(articles).map(({ tag }) => ({
		params: { tag },
		props: {
			articles: sortByPubDateDesc(articles.filter((article) => article.data.tags.includes(tag))),
		},
	}));
}

const { tag } = Astro.params;
const { articles } = Astro.props;
---

<BaseLayout title={`Tag: ${tag}`} description={`タグ「${tag}」の記事一覧`}>
	<PageHeader eyebrow={`${articles.length} stories`} title={`#${tag}`} description="このテーマに関連する記事をまとめています。" />
	<div class="list">
		{
			articles.map((article) => (
				<ArticleCard
					slug={article.id}
					title={article.data.title}
					summary={excerpt(article.data, article.body)}
					pubDate={article.data.pubDate}
					tags={article.data.tags}
				/>
			))
		}
	</div>
	<p class="back"><a href="/tags/">← タグ一覧へ</a></p>
</BaseLayout>

<style>
	.lead {
		color: var(--color-text-muted);
		font-size: 0.9rem;
	}

	.list {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.back {
		margin-top: 2rem;
	}

	@media (max-width: 800px) { .list { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 560px) { .list { grid-template-columns: 1fr; } }
</style>
