---
import { getCollection, render } from "astro:content";
import TagList from "../../components/TagList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { excerpt, formatDate, getAdjacentArticles, isPublishable } from "../../utils/articles";

export async function getStaticPaths() {
	const articles = await getCollection("articles", ({ data }) =>
		isPublishable(data, import.meta.env.PROD),
	);
	return articles.map((article) => {
		const { newer, older } = getAdjacentArticles(articles, article.id);
		return {
			params: { slug: article.id },
			props: {
				article,
				newer: newer && { slug: newer.id, title: newer.data.title },
				older: older && { slug: older.id, title: older.data.title },
			},
		};
	});
}

const { article, newer, older } = Astro.props;
const { Content } = await render(article);
const { title, pubDate, updatedDate, tags } = article.data;
---

<BaseLayout title={title} description={excerpt(article.data, article.body)}>
	<article>
		<header>
			<h1>{title}</h1>
			<p class="meta">
				<time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
				{
					updatedDate && (
						<span>
							(更新: <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>)
						</span>
					)
				}
			</p>
			<div class="article-tags">
				<TagList tags={tags} />
			</div>
		</header>
		<div class="body" data-pagefind-body>
			<Content />
		</div>
		<footer>
			<nav class="adjacent" aria-label="前後の記事">
				{
					newer && (
						<a class="newer" href={`/articles/${newer.slug}/`}>
							← {newer.title}
						</a>
					)
				}
				{
					older && (
						<a class="older" href={`/articles/${older.slug}/`}>
							{older.title} →
						</a>
					)
				}
			</nav>
			<a href="/articles/">記事一覧へ</a>
		</footer>
	</article>
</BaseLayout>

<style>
	header h1 {
		margin-bottom: 0.25rem;
	}

	.meta {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	.article-tags {
		margin: 0 0 1rem;
		font-size: 0.8rem;
	}

	.body :global(pre) {
		padding: 1rem;
		border-radius: var(--radius);
		overflow-x: auto;
	}

	.body :global(img) {
		max-width: 100%;
	}

	footer {
		margin-top: 2.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
	}

	.adjacent {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
		font-size: 0.9rem;
	}

	.adjacent .older {
		margin-left: auto;
		text-align: right;
	}
</style>
