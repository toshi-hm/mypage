---
import { getCollection } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { excerpt, isPublishable, sortByPubDateDesc } from "../../utils/articles";

const articles = sortByPubDateDesc(
	await getCollection("articles", ({ data }) => isPublishable(data, import.meta.env.PROD)),
);
---

<BaseLayout title="Articles" description="toshi-hm の記事一覧">
	<h1>Articles</h1>
	{articles.length === 0 && <p>まだ記事がありません。</p>}
	<div class="list">
		{
			articles.map((article) => (
				<ArticleCard
					slug={article.id}
					title={article.data.title}
					summary={excerpt(article.data, article.body)}
					pubDate={article.data.pubDate}
					tags={article.data.tags}
				/>
			))
		}
	</div>
</BaseLayout>

<style>
	.list {
		display: grid;
		gap: 0.75rem;
	}
</style>
