{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "plugins": ["typescript", "react", "oxc", "unicorn"],
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "env": {
    "browser": true
  },
  "ignorePatterns": ["dist/**", "storybook-static/**", ".astro/**", ".wrangler/**"]
}
