{
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun install:*)",
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(bunx oxfmt:*)",
      "Bash(bunx oxlint:*)",
      "Bash(bunx markdownlint-cli2:*)",
      "Bash(bunx astro:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d node_modules || bun install"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun .claude/hooks/format-file.ts"
          }
        ]
      }
    ]
  }
}
